# Copy this to .env and fill in your values

# Basic Auth credentials (default: admin / watchlist)
AUTH_USERNAME=admin
AUTH_PASSWORD=your_secure_password_here

# TMDB API Key - get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Anthropic API Key - for smart link identification (any URL → movie/show)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Bot (optional - for adding items via Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string
