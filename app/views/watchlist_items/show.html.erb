<% content_for :title, @item.title %>

<!-- Backdrop -->
<% if @item.backdrop_url %>
  <div class="relative -mx-4 sm:-mx-6 lg:-mx-8 -mt-8 mb-8 h-64 sm:h-80 overflow-hidden">
    <img src="<%= @item.backdrop_url %>" alt="" class="w-full h-full object-cover">
    <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-950/60 to-transparent"></div>
  </div>
<% end %>

<div class="flex flex-col md:flex-row gap-8">
  <!-- Poster -->
  <div class="flex-shrink-0">
    <% if @item.poster_url %>
      <img src="<%= @item.poster_url("w342") %>"
           alt="<%= @item.title %>"
           class="w-48 md:w-56 rounded-xl shadow-2xl mx-auto md:mx-0">
    <% else %>
      <div class="w-48 md:w-56 aspect-[2/3] bg-gray-800 rounded-xl flex items-center justify-center mx-auto md:mx-0">
        <svg class="w-16 h-16 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
        </svg>
      </div>
    <% end %>
  </div>

  <!-- Details -->
  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <div class="flex items-center gap-2 mb-2 flex-wrap">
          <span class="text-xs font-medium px-2.5 py-1 rounded-full <%= @item.media_type == 'tv' ? 'bg-purple-600/20 text-purple-400 border border-purple-600/30' : 'bg-blue-600/20 text-blue-400 border border-blue-600/30' %>">
            <%= @item.media_type == 'tv' ? 'TV Show' : 'Movie' %>
          </span>
          <span class="text-xs font-medium px-2.5 py-1 rounded-full <%= @item.watched? ? 'bg-green-600/20 text-green-400 border border-green-600/30' : 'bg-yellow-600/20 text-yellow-400 border border-yellow-600/30' %>">
            <%= @item.status_label %>
          </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-1"><%= @item.title %></h1>
        <div class="flex items-center gap-3 text-gray-400 text-sm flex-wrap">
          <% if @item.release_year %><span><%= @item.release_year %></span><% end %>
          <% if @item.formatted_runtime %><span><%= @item.formatted_runtime %></span><% end %>
          <% if @item.vote_average.present? && @item.vote_average > 0 %>
            <span class="flex items-center gap-1 text-yellow-400 font-medium">
              ★ <%= @item.vote_average.round(1) %>
            </span>
          <% end %>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <%= link_to edit_watchlist_item_path(@item), class: "p-2 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-white transition-colors" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        <% end %>
        <%= button_to watchlist_item_path(@item), method: :delete,
            data: { turbo_confirm: "Remove \"#{@item.title}\" from your watchlist?" },
            class: "p-2 rounded-lg bg-gray-800 hover:bg-red-900/50 text-gray-400 hover:text-red-400 transition-colors" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        <% end %>
      </div>
    </div>

    <!-- Genres -->
    <% if @item.genres_list.any? %>
      <div class="flex flex-wrap gap-2 mt-4">
        <% @item.genres_list.each do |genre| %>
          <span class="text-xs px-3 py-1 bg-gray-800 text-gray-300 rounded-full border border-gray-700"><%= genre %></span>
        <% end %>
      </div>
    <% end %>

    <!-- Overview -->
    <% if @item.overview.present? %>
      <p class="mt-4 text-gray-300 leading-relaxed"><%= @item.overview %></p>
    <% end %>

    <!-- Streaming info -->
    <% if @item.streaming_service.present? || @item.streaming_url.present? %>
      <div class="mt-6 p-4 bg-gray-800/50 rounded-xl border border-gray-700">
        <p class="text-sm font-medium text-gray-400 mb-2">Available on</p>
        <div class="flex items-center gap-3">
          <span class="text-white font-semibold"><%= @item.streaming_service || "Unknown service" %></span>
          <% if @item.streaming_url.present? %>
            <%= link_to @item.streaming_url, target: "_blank", rel: "noopener", class: "flex items-center gap-1.5 text-indigo-400 hover:text-indigo-300 text-sm transition-colors" do %>
              Watch now
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Cast -->
    <% if @item.cast_list.any? %>
      <div class="mt-6">
        <p class="text-sm font-medium text-gray-400 mb-2">Starring</p>
        <div class="flex flex-wrap gap-2">
          <% @item.cast_list.each do |actor| %>
            <span class="text-sm px-3 py-1 bg-gray-800 text-gray-300 rounded-full border border-gray-700"><%= actor %></span>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Notes -->
    <% if @item.notes.present? %>
      <div class="mt-4 p-4 bg-gray-800/50 rounded-xl border border-gray-700">
        <p class="text-sm font-medium text-gray-400 mb-2">Notes</p>
        <p class="text-gray-300 text-sm leading-relaxed"><%= @item.notes %></p>
      </div>
    <% end %>

    <!-- Toggle status -->
    <div class="mt-6">
      <%= button_to toggle_status_watchlist_item_path(@item), method: :patch,
          class: "flex items-center gap-2 #{@item.want_to_watch? ? 'bg-green-600 hover:bg-green-500' : 'bg-gray-700 hover:bg-gray-600'} text-white font-medium px-6 py-3 rounded-xl transition-colors" do %>
        <% if @item.want_to_watch? %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Mark as Watched
        <% else %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Move to Want to Watch
        <% end %>
      <% end %>
    </div>

    <!-- Watched at -->
    <% if @item.watched_at.present? %>
      <p class="text-xs text-gray-600 mt-3">Watched <%= time_ago_in_words(@item.watched_at) %> ago</p>
    <% end %>
  </div>
</div>

<div class="mt-8">
  <%= link_to "← Back to watchlist", watchlist_items_path, class: "text-sm text-gray-500 hover:text-gray-300 transition-colors" %>
</div>
