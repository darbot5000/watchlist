<% content_for :title, "Add to Watchlist" %>

<div class="max-w-2xl" data-controller="watchlist-search">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-white">Add to Watchlist</h1>
    <p class="text-gray-400 text-sm mt-1">Search by title, or paste any link — Netflix, YouTube, Wikipedia, IMDB — and we'll figure out the rest.</p>
  </div>

  <!-- Unified search input -->
  <div class="flex gap-2 mb-4">
    <input
      type="text"
      data-watchlist-search-target="input"
      data-action="input->watchlist-search#onInput keydown->watchlist-search#onKeydown"
      placeholder="Search by title, or paste a link…"
      autofocus
      class="flex-1 bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-base"
    >
    <button
      type="button"
      data-action="click->watchlist-search#onSearch"
      class="bg-indigo-600 hover:bg-indigo-500 text-white font-medium px-5 py-3 rounded-xl transition-colors flex-shrink-0"
    >
      Search
    </button>
  </div>

  <!-- Spinner -->
  <div data-watchlist-search-target="spinner" class="hidden flex items-center gap-2 mb-4 text-gray-400 text-sm">
    <svg class="animate-spin w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
    </svg>
    <span>Loading…</span>
  </div>

  <!-- Error -->
  <div data-watchlist-search-target="error" class="hidden mb-4 text-red-400 text-sm bg-red-900/30 border border-red-700/50 rounded-lg px-3 py-2"></div>

  <!-- Results -->
  <div data-watchlist-search-target="results" class="space-y-3"></div>

  <div class="mt-6">
    <%= link_to "← Back to Watchlist", watchlist_items_path, class: "text-gray-500 hover:text-gray-300 text-sm transition-colors" %>
  </div>
</div>
