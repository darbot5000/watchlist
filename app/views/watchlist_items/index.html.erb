<% content_for :title, "Watchlist" %>

<!-- Header & Filters -->
<div class="mb-8">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-white">My Watchlist</h1>
      <p class="text-gray-400 text-sm mt-1">
        <span id="counts">
          <%= render "counts" %>
        </span>
      </p>
    </div>
  </div>

  <!-- Filter tabs -->
  <div class="flex flex-wrap gap-2">
    <%= link_to "All", watchlist_items_path(params.permit(:media_type, :service)),
        class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:status].blank? ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white hover:bg-gray-700'}" %>
    <%= link_to "Want to Watch", watchlist_items_path(params.permit(:media_type, :service).merge(status: "want_to_watch")),
        class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:status] == 'want_to_watch' ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white hover:bg-gray-700'}" %>
    <%= link_to "Watched", watchlist_items_path(params.permit(:media_type, :service).merge(status: "watched")),
        class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:status] == 'watched' ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white hover:bg-gray-700'}" %>

    <div class="w-px bg-gray-700 mx-1 self-stretch"></div>

    <%= link_to "Movies", watchlist_items_path(params.permit(:status, :service).merge(media_type: "movie")),
        class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:media_type] == 'movie' ? 'bg-purple-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white hover:bg-gray-700'}" %>
    <%= link_to "TV Shows", watchlist_items_path(params.permit(:status, :service).merge(media_type: "tv")),
        class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:media_type] == 'tv' ? 'bg-purple-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white hover:bg-gray-700'}" %>

    <% if @available_services.any? %>
      <div class="w-px bg-gray-700 mx-1 self-stretch"></div>
      <% @available_services.each do |service| %>
        <%= link_to service, watchlist_items_path(params.permit(:status, :media_type).merge(service: service)),
            class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:service] == service ? 'bg-teal-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white hover:bg-gray-700'}" %>
      <% end %>
    <% end %>

    <% if params[:status].present? || params[:media_type].present? || params[:service].present? %>
      <%= link_to "Clear filters", watchlist_items_path,
          class: "px-4 py-2 rounded-full text-sm font-medium text-gray-500 hover:text-gray-300 transition-colors" %>
    <% end %>
  </div>
</div>

<!-- Items grid -->
<% if @items.any? %>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
    <% @items.each do |item| %>
      <%= render "card", item: item %>
    <% end %>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <div class="w-16 h-16 bg-gray-800 rounded-2xl flex items-center justify-center mb-4">
      <svg class="w-8 h-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
      </svg>
    </div>
    <h3 class="text-lg font-semibold text-gray-300 mb-2">Nothing here yet</h3>
    <p class="text-gray-500 text-sm mb-6">Add your first movie or show to get started.</p>
    <%= link_to "Add something", new_watchlist_item_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-6 py-3 rounded-lg transition-colors" %>
  </div>
<% end %>
